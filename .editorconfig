# EditorConfig — https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{sh,bash}]
indent_style = space
indent_size = 4

[{.bashrc,.bash_aliases,.bashrc_help,.zshrc,.zshrc_help,config.fish,fish_help}]
indent_style = space
indent_size = 4

[*.{yml,yaml}]
indent_style = space
indent_size = 2

[*.md]
# Trailing spaces are meaningful (hard line breaks) in Markdown
trim_trailing_whitespace = false

[*.toml]
indent_style = space
indent_size = 2
